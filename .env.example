PORT=3000
REDIS_URL=redis://localhost:6379
MAX_SECRET_BYTES=65536
MIN_TTL_SECONDS=60
MAX_TTL_SECONDS=604800

# ── Environment ─────────────────────────────────────────────────────────────
# DEVELOPMENT (current): HTTP allowed, no TLS enforcement
NODE_ENV=development
# PRODUCTION: uncomment below and comment NODE_ENV=development
# Requires a reverse proxy (nginx/traefik) terminating TLS upstream.
# NODE_ENV=production

# ── Redis ───────────────────────────────────────────────────────────────────
# DEVELOPMENT (current): no password required
# REDIS_PASSWORD=
# PRODUCTION: generate with: openssl rand -hex 32
# REDIS_PASSWORD=your-strong-password-here
