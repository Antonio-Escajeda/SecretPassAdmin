# ── Cómo levantar ───────────────────────────────────────────────────────────
#
# DESARROLLO (por defecto):
#   docker compose up -d
#
# PRODUCCIÓN:
#   Copiá este archivo a .env, completá REDIS_PASSWORD y ejecutá:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d
#
#   Requiere un reverse proxy (nginx/traefik) terminando TLS upstream.
#
# ────────────────────────────────────────────────────────────────────────────

PORT=3000
REDIS_URL=redis://redis:6379
MAX_SECRET_BYTES=65536
MIN_TTL_SECONDS=60
MAX_TTL_SECONDS=604800

# ── Redis ───────────────────────────────────────────────────────────────────
# Requerido en producción. Generá con: openssl rand -hex 32
# REDIS_PASSWORD=
